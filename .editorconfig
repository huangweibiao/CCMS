# EditorConfig for CCMS Project

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

# Matches multiple file extensions
[*.{js,ts,vue}]
indent_size = 2
max_line_length = 120

[*.java]
indent_size = 4
max_line_length = 120

[*.xml]
indent_size = 2

[*.yml,*.yaml]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[package.json]
indent_size = 2

[Makefile]
indent_style = tab