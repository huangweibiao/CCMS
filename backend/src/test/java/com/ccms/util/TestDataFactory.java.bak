        entity.setMainId(mainId);
        entity.setExpenseType("交通费");
        entity.setExpenseAmount(new BigDecimal("500.00"));
        entity.setExpenseDate(LocalDate.now());
        entity.setCreateTime(LocalDateTime.now());
        return entity;
    }

