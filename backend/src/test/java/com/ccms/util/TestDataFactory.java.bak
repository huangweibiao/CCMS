    // ==================== 批量创建方法 ====================

    /**
     * 批量创建费用申请
     */
    public static List List<ExpenseApplyMain> createExpenseApplyMainList(int count) {
        List List<ExpenseApplyMain> list = new ArrayList<>();
        for (int i = 0; i < count; i++) {
            list.add(createExpenseApplyMain());
        }
        return list;
    }

    /**
     * 批量创建用户
     */
    public static List List<SysUser> createSysUserList(int count) {
        List List<SysUser> list = new ArrayList<>();
        for (int i = 0; i < count; i++) {
            SysUser user = createSysUser();
            user.setUserName("测试用户" + (i + 1));
            user.setLoginName("testuser" + (i + 1));
            list.add(user);
        }
        return list;
    }

    /**
     * 重置ID计数器（用于测试隔离）
     */
    public static void resetIdCounter() {
        idCounter = 1L;
    }
}
