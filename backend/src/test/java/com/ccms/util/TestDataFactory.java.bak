    public static SysLog createSysLog() {
        SysLog entity = new SysLog();
        entity.setId(generateId());
        entity.setLogType("OPERATION");
        entity.setLogTitle("测试操作");
        entity.setOperationType("CREATE");
        entity.setRequestMethod("POST");
        entity.setRequestUrl("/api/test");
        entity.setRequestParams("{}");
        entity.setResponseData("{}");
        entity.setUserId(1L);
