/**
 * 测试数据工厂类
 * 用于生成各种测试实体对象
 */
public class TestDataFactory {

    private static Long idCounter = 1L;

    /**
     * 生成唯一ID
     */
    public static Long generateId() {
        return idCounter++;
    }

    /**
     * 生成编码
     */
    public static String generateCode(String prefix) {
        return prefix + System.currentTimeMillis();
    }

    /**
     * 创建费用申请主表
     */
    public static ExpenseApplyMain createExpenseApplyMain() {
        ExpenseApplyMain entity = new ExpenseApplyMain();
        entity.setId(generateId());
        entity.setApplyNo(generateCode("EXP"));
        entity.setApplyType("TRAVEL");
        entity.setApplyStatus(0);
        entity.setApplyAmount(new BigDecimal("1000.00"));
        entity.setApplyUserId(1L);
        entity.setApplyUserName("测试用户");
        entity.setApplyDeptId(1L);
        entity.setApplyDeptName("测试部门");
        entity.setApplyDate(LocalDate.now());
        entity.setCreateTime(LocalDateTime.now());
        entity.setUpdateTime(LocalDateTime.now());
        entity.setCreateBy("admin");
        entity.setUpdateBy("admin");
        entity.setDelFlag(0);
        return entity;
    }

    /**
     * 创建费用申请明细
