{
  "name": "ccms-frontend",
  "version": "1.0.0",
  "description": "企业级费控管理系统前端",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "serve": "vite preview --port 3000",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "vue": "^3.5.12",
    "vue-router": "^4.4.6",
    "pinia": "^3.2.1",
    "axios": "^1.7.9",
    "element-plus": "^2.8.7",
    "@element-plus/icons-vue": "^2.5.0",
    "dayjs": "^1.11.13",
    "lodash-es": "^4.17.21",
    "@vueuse/core": "^11.1.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.9.3",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.13.0",
    "eslint-plugin-vue": "^9.27.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "~5.6.2",
    "vite": "^6.0.1",
    "vue-tsc": "^2.0.27",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}