{
  "extends": "@istanbuljs/nyc-config-typescript",
  "all": true,
  "check-coverage": true,
  "reporter": ["text", "text-summary", "html", "lcov", "json"],
  "report-dir": "./coverage",
  "temp-dir": "./.nyc_output",
  "include": [
    "../frontend/src/**/*"
  ],
  "exclude": [
    "../frontend/src/**/*.test.ts",
    "../frontend/src/**/*.spec.ts",
    "../frontend/src/**/__tests__/**",
    "../frontend/node_modules/**",
    "../frontend/dist/**",
    "../frontend/build/**"
  ],
  "extension": [
    ".ts",
    ".tsx",
    ".vue"
  ],
  "branches": 80,
  "lines": 80,
  "functions": 80,
  "statements": 80
}
