{
  "name": "ccms-ui-tests",
  "version": "1.0.0",
  "description": "CCMS系统UI自动化测试",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:debug": "playwright test --debug",
    "test:report": "playwright test --reporter=html",
    "test:coverage": "npx nyc playwright test",
    "report": "playwright show-report",
    "report:allure": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "report:coverage": "npx nyc report --reporter=html --reporter=text",
    "install-browsers": "playwright install",
    "codegen": "playwright codegen",
    "screenshot": "playwright screenshot",
    "lint": "eslint tests/**/*.ts",
    "format": "prettier --write tests/**/*.ts"
  },
  "keywords": [],
  "author": "CCMS Development Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "allure-playwright": "^2.15.1",
    "eslint": "^8.57.0",
    "nyc": "^15.1.0",
    "prettier": "^3.2.5"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0"
  }
}
